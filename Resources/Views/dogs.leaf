#extend("base"):
#export("content"):
<div class="container">
    <h1 class="page-title">#(title)</h1>
    <div class="card-grid">
        #for(dog in dogs):
        <a class="card" href="#(dog.url)">
            <div class="card-photo">
                <img src="#(dog.photo)" alt="#(dog.name)" loading="lazy">
            </div>
            <span class="card-name">#(dog.name)</span>
        </a>
        #endfor
    </div>
</div>
#endexport
#endextend
